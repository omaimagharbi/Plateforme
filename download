# Copiez ce fichier en ".env.local" et remplissez les valeurs avant de lancer le projet.

# Chaîne de connexion PostgreSQL (Neon, Supabase, Railway, etc.)
# Exemple Neon : postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Chaîne aléatoire longue et secrète utilisée pour signer les sessions (cookies)
# Générez-en une avec : openssl rand -base64 48
JWT_SECRET=

# Votre clé API Anthropic (https://console.anthropic.com/settings/keys)
# Nécessaire pour les fonctionnalités IA (Risk Predictor, Bouton Élan)
ANTHROPIC_API_KEY=
